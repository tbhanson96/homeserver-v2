{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(png|jpg|jpeg|svg|webp|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "google-font-stylesheets",
      "urls": [
        "https://fonts.googleapis.com/**"
      ],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "7d",
        "strategy": "freshness",
        "timeout": "10s"
      }
    },
    {
      "name": "google-font-webfonts",
      "urls": [
        "https://fonts.gstatic.com/**"
      ],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "30d",
        "strategy": "performance"
      }
    }
  ]
}
