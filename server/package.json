{
  "name": "homeserver-server",
  "version": "0.0.1",
  "description": "",
  "author": "Tim Hanson",
  "license": "MIT",
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && nest build && npm run swagger",
    "swagger": "ts-node swagger-doc-gen.ts",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "start:watch": "nest start -w",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.3.2",
    "@nestjs/websockets": "11.1.19",
    "@types/http-proxy": "1.17.17",
    "@types/http-proxy-middleware": "0.19.3",
    "@types/nodemailer": "8.0.0",
    "@types/tar": "6.1.10",
    "cheerio": "1.2.0",
    "epub": "2.1.1",
    "flat": "6.0.1",
    "http-proxy-middleware": "3.0.5",
    "jsonfile": "6.2.1",
    "libgen": "2.1.2",
    "memfs": "4.57.2",
    "mongoose": "9.5.0",
    "morgan": "1.10.1",
    "ncp": "2.0.0",
    "node-calibre": "2.1.1",
    "nodemailer": "8.0.5",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1",
    "tar": "7.5.13",
    "zip-lib": "1.3.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/testing": "11.1.19",
    "@tsconfig/node24": "24.0.4",
    "@types/express": "5.0.6",
    "@types/flat": "5.0.5",
    "@types/jest": "30.0.0",
    "@types/jsonfile": "6.1.4",
    "@types/morgan": "1.9.10",
    "@types/multer": "2.1.0",
    "@types/node": "25.6.0",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/supertest": "7.2.0",
    "jest": "30.3.0",
    "mkdirp": "3.0.1",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tslint": "5.20.1",
    "typescript": "6.0.3",
    "webpack": "5.106.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "test",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!flat/|epub/)"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
